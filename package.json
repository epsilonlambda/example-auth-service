{
  "name": "example-auth-service",
  "version": "0.1.0",
  "private": true,
  "description": "Credential management and authentication API for internal services",
  "type": "module",
  "imports": {
    "#app/*": "./src/app/*",
    "#test/*": "./test/*"
  },
  "engines": {
    "node": ">=24.7.0"
  },
  "scripts": {
    "dev": "node --watch src/server.ts",
    "start": "node src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "node --test \"test/**/*.test.ts\"",
    "coverage": "node --test --experimental-test-coverage \"test/**/*.test.ts\"",
    "coverage:lcov": "mkdir -p coverage && node --test --experimental-test-coverage --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage/lcov.info \"test/**/*.test.ts\"",
    "test:e2e": "E2E_BASE_URL=http://127.0.0.1:3000 node --test test/e2e.test.ts",
    "check": "npm run typecheck && npm run lint && npm test"
  },
  "dependencies": {
    "fastify": "5.10.0",
    "fastify-plugin": "6.0.0",
    "redis": "6.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@fastify/type-provider-json-schema-to-ts": "5.0.0",
    "@types/node": "26.1.1",
    "json-schema-to-ts": "3.1.1",
    "typescript": "7.0.2"
  }
}
