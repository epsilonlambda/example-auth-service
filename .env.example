# Environment variables read by the service, with their defaults.
# This file is documentation: nothing loads it automatically. The app reads
# real process env only; copy to .env and export it (or wire env_file in
# compose) if you want file-based configuration. .env itself is gitignored.

# HTTP port the server binds. Also read by the container healthcheck probe.
PORT=3000

# Redis connection string. The compose file overrides this to
# redis://redis:6379 (the in-network service); the default suits a locally
# running Redis during development.
REDIS_URL=redis://127.0.0.1:6379

# Test-only gate: when set, test/e2e.test.ts runs against that base URL over
# real HTTP. `npm run test:e2e` sets it; plain `npm test` leaves it unset and
# reports the E2E tests as skipped.
#E2E_BASE_URL=http://127.0.0.1:3000

# Set by the container image; local development runs without it.
#NODE_ENV=production

# Node runtime dial, not read by app code: password hashing rides the libuv
# threadpool (default 4 threads), which caps concurrent hashes per process.
# Sizing guidance belongs with production notes; the default is right for the
# demo (CPU-bound work gains nothing from threads > cores).
#UV_THREADPOOL_SIZE=4
